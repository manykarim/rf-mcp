{
  "mcpServers": {
    "RobotMCP": {
      "type": "stdio",
      "command": "uv",
      "tools": ["*"],
      "args": [
        "run",
        "--directory",
        "__PROJECT_DIR__",
        "-m",
        "robotmcp.server"
      ],
      "env": {
        "ROBOTMCP_INSTRUCTIONS": "default",
        "ROBOTMCP_OUTPUT_MODE": "auto"
      }
    }
  }
}
